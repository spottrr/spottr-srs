% Styling for KU SKE SRS Documentation
% Clean, modern styling based on 12pt base

\NeedsTeXFormat{LaTeX2e}
\ProcessOptions\relax

% set page geometry - clean margins similar to article style
\usepackage[a4paper]{geometry}
\AtBeginDocument{
    \newgeometry{
        width=150mm,
        top=25mm,
        bottom=25mm
    }
}

\widowpenalty=10000
\clubpenalty=10000
\sloppy

% simple page numbers at bottom center
\usepackage{fancyhdr}
\fancyhf{}
\pagestyle{fancy}
\renewcommand{\headrulewidth}{0pt}
\fancyfoot[C]{\thepage}

% renew fonts - 12pt base, standard LaTeX scaling
\renewcommand{\normalsize}{
    \@setfontsize\normalsize\@xiipt{14.5}%
    \abovedisplayskip 12\p@ \@plus3\p@ \@minus7\p@
    \abovedisplayshortskip \z@ \@plus3\p@
    \belowdisplayshortskip 6.5\p@ \@plus3.5\p@ \@minus3\p@
    \belowdisplayskip \abovedisplayskip
    \let\@listi\@listI
}
\normalsize
\renewcommand{\small}{
    \@setfontsize\small\@xpt{12}%
    \abovedisplayskip 10\p@ \@plus2\p@ \@minus5\p@
    \abovedisplayshortskip \z@ \@plus3\p@
    \belowdisplayshortskip 6\p@ \@plus3\p@ \@minus3\p@
    \def\@listi{\leftmargin\leftmargini
        \topsep 6\p@ \@plus2\p@ \@minus2\p@
        \parsep 3\p@ \@plus2\p@ \@minus\p@
        \itemsep \parsep}%
    \belowdisplayskip \abovedisplayskip
}
\newcommand{\moderate}{
    \@setfontsize\moderate\@xivpt{18}
}
\renewcommand{\large}{
    \@setfontsize\large{14.4}{18}
}
\renewcommand{\Large}{
    \@setfontsize\Large{17.28}{22}
}
\renewcommand{\LARGE}{
    \@setfontsize\LARGE{20.74}{25}
}
\renewcommand{\huge}{
    \@setfontsize\huge{24.88}{30}
}
\renewcommand{\Huge}{
    \@setfontsize\Huge{24.88}{30}
}

%% reformat the chapters & sections - cleaner, less vertical space
% chapter-level
\renewcommand{\chapter}{\thispagestyle{fancy}%
    \global\@topnum\z@
    \secdef\@chapter\@schapter
}
\def\@chapter[#1]#2{\ifnum \c@secnumdepth >\m@ne
                         \refstepcounter{chapter}%
                         \typeout{\@chapapp\space\thechapter.}%
                         \addcontentsline{toc}{chapter}%
                                   {\protect Chapter \numberline{\thechapter}#1}%
                    \else
                      \addcontentsline{toc}{chapter}{#1}%
                    \fi
                    \chaptermark{#1}%
                    \if@twocolumn
                      \@topnewpage[\@makechapterhead{#2}]%
                    \else
                      \@makechapterhead{#2}%
                      \@afterheading
                    \fi}

% chapter heading - centered
\def\@makechapterhead#1{%
    \begin{center}
        {\normalfont
            \ifnum \c@secnumdepth >\m@ne
                \Large\bfseries \@chapapp\space \thechapter
                \par\nobreak
                \vskip 8\p@
            \fi
            \interlinepenalty\@M
            \LARGE \bfseries #1\par\nobreak
        }
    \end{center}
    \vskip 16\p@
}

% unnumbered chapter heading - centered
\def\@makeschapterhead#1{%
    \begin{center}
        {\normalfont
            \interlinepenalty\@M
            \LARGE \bfseries #1\par\nobreak
        }
    \end{center}
    \vskip 16\p@
}

% section-level - clean, standard sizes
\renewcommand\section{\@startsection {section}{1}{\z@}%
                                   {-3ex \@plus -1ex \@minus -.2ex}%
                                   {2ex \@plus.2ex}%
                                   {\normalfont\Large\bfseries}}

% subsection-level - no indent offset
\renewcommand\subsection{\@startsection{subsection}{2}{\z@}%
                                     {-2.5ex\@plus -1ex \@minus -.2ex}%
                                     {1.5ex \@plus .2ex}%
                                     {\normalfont\large\bfseries}}

% subsubsection-level
\renewcommand\subsubsection{\@startsection{subsubsection}{3}{\z@}%
                                     {-2ex\@plus -1ex \@minus -.2ex}%
                                     {1ex \@plus .2ex}%
                                     {\normalfont\normalsize\bfseries}}

%% image placeholder command
% Usage: \imgplaceholder{width}{height}{caption text}
\usepackage{xcolor}
\newcommand{\imgplaceholder}[3]{%
    \begin{figure}[H]
        \centering
        \fcolorbox{black!40}{black!8}{%
            \parbox{#1}{%
                \vspace{#2}
                \centering
                \textcolor{black!40}{\large\bfseries #3}
                \vspace{#2}
            }%
        }
        \caption{#3}
    \end{figure}
}

%% modify TOC
\renewcommand\contentsname{Table of Contents}
\makeatletter
\renewcommand\@dotsep{4.5}
\makeatother

\endinput
